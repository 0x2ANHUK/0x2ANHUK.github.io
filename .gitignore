# Echo Nexus Archive — Git Ignore Rules
# Prevent accidental commits of sensitive data

# Environment & Credentials
.env
.env.local
.env.*.local
*.key
*.pem
*.p8
*.p12
*.pfx
secret*
credential*
config.yml
config.yaml
.aws/
.ssh/

# API Keys & Tokens
.apikey
.token
.access_token
.refresh_token
.bearer_token

# Database & Server
.db
*.sqlite
*.sqlite3
.mysql_*
.postgres_*
.mongodb_*
.firebase_*

# Private Data
.private/
private/
secrets/
vault/
.vault/

# User-specific files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.iml

# Build artifacts (if any)
dist/
build/
node_modules/
.npm/

# Temporary files
*.tmp
*.temp
.tmp/
tmp/

# Logs (except git logs which are OK)
debug.log
error.log
*.log

# macOS
.AppleDouble
.LSOverride

# OS
.history/
.env.backup

# CI/CD secrets
.travis.yml (with secrets)
.github/secrets/

# Email addresses & personal info
*email.txt
*contact.txt
*password.txt

# GPG keys
.gnupg/
*.gpg

# SSH keys
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub

# Docker secrets
.dockercfg
.docker/config.json

# npm/yarn
.npmrc
.yarnrc

# Git credentials
.git-credentials
.gitcredentials
screenshots/
