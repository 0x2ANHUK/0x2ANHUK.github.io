ODtoPTYwO2NmPXdlYnA-/https://s.yimg.com/os/creatr-uploaded-images/2020-12/d7f38f00-340b-11eb-b7bf-540525a865da"/></div><div class="relative"><img alt="Yahoo Movies UK" width="208" height="30" decoding="async" data-nimg="1" class="hidden w-auto dark:block dark:h-[30px]" style="color:transparent" src="https://s.yimg.com/ny/api/res/1.2/yBdhB7CJQFYUqcqiYJzheA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTQxNjtoPTYwO2NmPXdlYnA-/https://s.yimg.com/os/creatr-uploaded-images/2020-09/b0c65950-fc00-11ea-b23c-77eb1d463ef0"/></div></a></div><h1 class="mt-2 text-[1.625rem] font-bold leading-tight md:text-[2rem]">&#x27;The Matrix&#x27; at 20: The actors who turned down the role of Neo</h1><div class=""><div class="flex items-start justify-between gap-3 flex-col lg:flex-row mt-3"><div class="flex items-start"><a data-ylk="elm:author;itc:0;sec:content-canvas;slk:Stefan Pape;" aria-hidden="true" class="relative mr-2 inline-block size-[42px] shrink-0" href="https://www.yahoo.com/author/stefan-pape/" tabindex="-1"><img alt="" role="img" loading="lazy" decoding="async" data-nimg="fill" class="size-full rounded-full object-cover object-center" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" src="https://s.yimg.com/ny/api/res/1.2/llaVzxxRZX2gLYbssDKO6Q--/YXBwaWQ9aGlnaGxhbmRlcjt3PTgwO2g9ODA7Y2Y9d2VicA--/https://s.yimg.com/os/creatr-uploaded-images/2018-09/7f725460-b825-11e8-99fd-0d0dc99b4455"/></a><div class="inline-block"><div class="text-sm font-semibold"><a data-ylk="elm:author;itc:0;sec:content-canvas;" class="text-inherit" href="https://www.yahoo.com/author/stefan-pape/">Stefan Pape</a><span class="font-normal">, <!-- -->Contributor</span></div><div class="text-xs text-muted md:text-sm flex lg:block"><div><time dateTime="2019-07-12T15:09:40.000Z">Fri 12 July 2019 at 3:09 pm UTC</time></div></div></div></div><div class="flex items-center gap-2 mt-1 lg:mt-1.5"><div class="relative"><div class="absolute z-10 flex w-64 items-start gap-2 rounded bg-black p-3 text-xs font-semibold tracking-wide text-white transition-opacity duration-200 ease-in-out bottom-12 left-[-0.75rem] opacity-0" id="add-to-google-tooltip-53a8586b-452f-3ec1-b454-abbe11255798" aria-hidden="true" role="tooltip"><div>Add Yahoo as a preferred source to see more of our stories on Google.</div><div class="absolute -bottom-4 left-8 -translate-x-1/2 border-8 border-transparent border-t-black"></div></div><a data-ylk="elm:partnercta;itc:0;sec:google-pub;" class="flex gap-2 text-nowrap rounded-[99px] border bg-white text-sm font-medium leading-4 text-gray-900 hover:no-underline border-carbon-4 leading-[1.125rem] transition-[background-color,box-shadow] duration-200 ease-in-out hover:bg-[#f4f3f0] hover:shadow-elevation-3 focus:bg-[#f4f3f0] focus:shadow-elevation-3 p-3" aria-label="Add Yahoo on Google" href="https://www.google.com/preferences/source?q=uk.movies.yahoo.com" rel="noopener noreferrer nofollow" target="_blank"><svg aria-hidden="true" class="align-middle text-carbon-13" focusable="false" height="16" viewBox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M12.2 5H9V1.8H3.8v12.4h8.4zM14 4v12H2V0h8.5zM5.1 8.1h2v-2h1.8v2h2v1.8h-2v2H7.1v-2h-2z"></path></svg></a></div><div class="relative inline-flex items-center h-[40px]"><button aria-controls="_R_2jkl8qoqk5elubsnqq5b_" aria-expanded="false" aria-haspopup="menu" aria-label="Share" class="rounded-full border p-3 transition-[background-color,box-shadow] duration-200 ease-in-out focus:shadow-elevation-3 hover:shadow-elevation-3 border-carbon-4 hover:bg-[#f4f3f0] focus:bg-[#f4f3f0] dark:bg-carbon-13 dark:hover:bg-carbon-11" data-ylk="elm:share;itc:1;sec:consolidated-share-popup;slk:share-menu-open;"><svg aria-hidden="true" class="text-gray-900 md:size-4" focusable="false" height="16" viewBox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M7.952 5.325V1.77l6.548 6.1-6.548 5.73V9.918h-.018a6.7 6.7 0 0 0-1.482.16c-1.444.325-2.502 1.105-3.311 1.964-.637.676-1.119 1.402-1.512 1.994l-.129.193q0-.14.002-.277c.013-.963.093-1.82.228-2.586.857-4.85 3.934-5.954 6.222-6.04M3.834 9.542c1.08-.662 2.43-1.127 4.12-1.125l1.498.002v1.877l2.81-2.46-2.81-2.618V6.77l-1.444.054c-1.105.042-2.297.366-3.218 1.304-.338.344-.67.802-.956 1.414"></path></svg></button></div></div></div></div></header><div class=""><figure class="relative mb-4"><div class="relative overflow-hidden -mx-4 md:mx-0 md:rounded-lg" style="aspect-ratio:1.5"><img alt="Keanu Reeves plays Neo in The Matrix - but it&#x27;s a role that could&#x27;ve gone elsewhere (WarnerBros)" decoding="async" data-nimg="fill" class="object-cover object-center" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" src="https://s.yimg.com/ny/api/res/1.2/ErpO9JK8CwOPIEu69HzCyg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI7aD03NzY7Y2Y9d2VicA--/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/294718d0-a4b2-11e9-b7f6-bac0660da6fc"/><button aria-label="View larger image" class="group absolute bottom-0 size-full" data-ylk="elm:expand;itc:1;sec:image-lightbox;slk:lightbox-open;"><span class="absolute bottom-3 right-3 rounded-full bg-white p-3 opacity-100 shadow-elevation-3 transition-opacity duration-300 group-hover:block group-hover:opacity-100 md:p-[17px] lg:bottom-6 lg:right-6 lg:bg-white/90 lg:p-5 lg:opacity-0 lg:shadow-none"><svg viewBox="0 0 22 22" aria-hidden="true" class="size-4 lg:size-6" width="22" height="22"><path d="M12.372.92c0-.506.41-.916.915-.916L21 0l-.004 7.712a.917.917 0 0 1-1.832 0V3.183l-6.827 6.828-1.349-1.348 6.828-6.828h-4.529a.915.915 0 0 1-.915-.915M1.835 17.816l6.828-6.828 1.349 1.349-6.829 6.827h4.529a.915.915 0 0 1 0 1.831L0 21l.004-7.713a.916.916 0 0 1 1.831 0z"></path></svg></span></button><dialog aria-label="Modal dialogue" aria-modal="true" class="fixed bottom-0 left-0 right-0 top-0 z-4 size-full max-h-none max-w-none bg-white hidden"></dialog></div><figcaption class="relative text-sm mt-1 pr-2.5"><div style="max-height:none;overflow:visible">Keanu Reeves plays Neo in The Matrix - but it's a role that could've gone elsewhere ((WarnerBros)</div></figcaption></figure></div><div class="max-w-screen-sm mx-auto"><div class="" data-article-body="true"><p class="mb-4 text-lg md:leading-8 break-words">20 years on from the release of <a href="https://uk.movies.yahoo.com/tagged/the-matrix" data-ylk="slk:The Matrix;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;The Matrix&quot;}" class="link "><em>The Matrix</em></a><em>,</em> and this iconic, seminal classic from the <a href="https://uk.movies.yahoo.com/tagged/the-wachowskis" data-ylk="slk:Wachowski siblings;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Wachowski siblings&quot;}" class="link ">Wachowski siblings </a>has left a cinematic imprint that has transcended generations – a luminary cinematic event that has left its mark on pop culture, and on the genre it sits within.</p><p class="mb-4 text-lg md:leading-8 break-words">Naturally, when dealing with a film of this nature it's impossible to imagine anybody else playing the leading role, which of course eventually fell into the lap of everybody's <a href="https://uk.movies.yahoo.com/fans-want-keanu-reeves-to-be-named-times-person-of-the-year-130235083.html" data-ylk="slk:current favourite actor Keanu Reeves;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;current favourite actor Keanu Reeves&quot;}" class="link  yahoo-link">current favourite actor Keanu Reeves</a>. Though we weren't far away from having to imagine a different Neo, as the list of actors – and actresses - who almost signed up to this project is quite remarkable.</p><p class="mb-4 text-lg md:leading-8 break-words">Firstly, and most famously, Neo was <a href="https://uk.movies.yahoo.com/will-smith-reveals-didnt-play-neo-matrix-163530775.html" data-ylk="slk:turned down by Will Smith;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;turned down by Will Smith&quot;}" class="link  yahoo-link">turned down by Will Smith</a>. The actor, who also <a href="https://uk.movies.yahoo.com/post/133852442661/will-smith-reveals-why-he-turned-down-tarantinos" data-ylk="slk:rejected the chance to work with Quentin Tarantino;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;rejected the chance to work with Quentin Tarantino&quot;}" class="link ">rejected the chance to work with Quentin Tarantino</a> and take on the eponymous lead role in <em>Django Unchained</em>, has admitted this decision may have been ill-judged, particularly as he instead went on to star in <em>Wild Wild West,</em> one of the biggest flops of his career.</p><iframe class="mb-4" height="auto" loading="lazy" src="https://www.youtube.com/embed/hm2szuXKgL8" style="aspect-ratio:1.78" title="youtube embed content" width="100%"></iframe><p class="mb-4 text-lg md:leading-8 break-words">During <a href="https://www.youtube.com/watch?v=hm2szuXKgL8" rel="nofollow noopener" target="_blank" data-ylk="slk:a video the actor posted online,;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;a video the actor posted online,&quot;}" class="link ">a video the actor posted online,</a> he explained why he made the call that he did. “The Wachowskis came in and they had only done one movie,” Smith said. “They came in and made a pitch for <em>The Matrix. </em>As it turns out, they're geniuses. But there's a fine line in a pitch meeting between genius, and what I experienced in the meeting.”</p><div class="max-md:faux-bleed mb-4 bg-marshmallow pb-5 dark:bg-ramones md:invisible md:mb-0 md:h-0 md:overflow-hidden md:pb-0"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_53758qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_53758qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_53758qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (max-width: 767.95px) {
        #_R_53758qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><div class="mb-4 hidden pb-5 md:block"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_93758qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_93758qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_93758qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (min-width: 768px) {
        #_R_93758qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><p class="mb-4 text-lg md:leading-8 break-words">Part of what makes<em> The Matrix</em> so memorable is the bullet time effect, which Smith jokingly admits sounded like a strange idea when pitched to him at the time.</p><p class="mb-4 text-lg md:leading-8 break-words"><strong>Read More: </strong><a href="https://uk.movies.yahoo.com/wachowskis-working-fourth-matrix-film-claims-john-wick-3-director-chad-stahelski-exclusive-122500310.html" data-ylk="slk:The Wachowskis are working on a fourth Matrix film;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;The Wachowskis are working on a fourth Matrix film&quot;}" class="link  yahoo-link"><strong>The Wachowskis are working on a fourth Matrix film</strong></a></p><p class="mb-4 text-lg md:leading-8 break-words">“This is the actual pitch they made. 'We're thinking like, imagine you're in a fight. You jump, but imagine if you could stop jumping in the middle of the jump. But then people could see around you 360 while you stop jumping. We're going to invent these cameras and then people can see the whole jump when you stop in the middle of the jump.' So I made Wild Wild West. I'm not proud of it.”</p><figure class="relative mb-4"><div class="relative"><img alt="Keanu Reeves is Neo, and it&#x27;s hard to imagine anyone else in the role (WarnerBros)" loading="lazy" width="960" height="631" decoding="async" data-nimg="1" class="rounded-lg" style="color:transparent" src="https://s.yimg.com/ny/api/res/1.2/woxXPxZbCi4FYxdWwqxhcg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTYzMTtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/6f238c60-a4b4-11e9-9b77-d71880602bcd"/><button aria-label="View larger image" class="group absolute bottom-0 size-full" data-ylk="elm:expand;itc:1;sec:image-lightbox;slk:lightbox-open;"><span class="absolute bottom-3 right-3 rounded-full bg-white p-3 opacity-100 shadow-elevation-3 transition-opacity duration-300 group-hover:block group-hover:opacity-100 md:p-[17px] lg:bottom-6 lg:right-6 lg:bg-white/90 lg:p-5 lg:opacity-0 lg:shadow-none"><svg viewBox="0 0 22 22" aria-hidden="true" class="size-4 lg:size-6" width="22" height="22"><path d="M12.372.92c0-.506.41-.916.915-.916L21 0l-.004 7.712a.917.917 0 0 1-1.832 0V3.183l-6.827 6.828-1.349-1.348 6.828-6.828h-4.529a.915.915 0 0 1-.915-.915M1.835 17.816l6.828-6.828 1.349 1.349-6.829 6.827h4.529a.915.915 0 0 1 0 1.831L0 21l.004-7.713a.916.916 0 0 1 1.831 0z"></path></svg></span></button><dialog aria-label="Modal dialogue" aria-modal="true" class="fixed bottom-0 left-0 right-0 top-0 z-4 size-full max-h-none max-w-none bg-white hidden"></dialog></div><figcaption class="relative text-sm mt-1 pr-2.5"><div style="max-height:none;overflow:visible">Keanu Reeves is Neo, and it's hard to imagine anyone else in the role (WarnerBros)</div></figcaption></figure><p class="mb-4 text-lg md:leading-8 break-words">He did, however, see a bright side in his decision. “If I had done it, because I'm black then Morpheus wouldn't have been black 'cause they were looking at <a href="https://uk.movies.yahoo.com/tagged/val-kilmer" data-ylk="slk:Val Kilmer;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Val Kilmer&quot;}" class="link ">Val Kilmer</a>. So I probably would've messed <em>The Matrix</em> up, I would have ruined it. I did you a favour.”</p><div class="max-md:faux-bleed mb-4 bg-marshmallow pb-5 dark:bg-ramones md:invisible md:mb-0 md:h-0 md:overflow-hidden md:pb-0"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_56758qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_56758qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_56758qoqk5elubsnqq5bH1_ { display: none; }
