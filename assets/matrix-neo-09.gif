px] rounded-lg lg:mr-3 lg:size-[80px]"><img alt="" loading="lazy" width="0" height="0" decoding="async" data-nimg="1" class="size-full object-cover" style="color:transparent" src="https://s.yimg.com/uu/api/res/1.2/fCutyUvL315q_Nq3pYlwbA--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/buzzfeed_articles_778/93491b1788b4cb08ec71c9db3d369108.cf.webp"/></div><div><h3 class="mb-1.5 text-[1.0625rem] font-semibold lg:text-[0.9375rem] lg:leading-[1.1875rem]"><a data-ylk="ct:story;elm:hdln;g:c81dcc9f-ef85-3948-8103-06c3008c0b88;itc:0;sec:trending-story-center;ll3:target-deeplink;" href="https://uk.news.yahoo.com/57-photos-made-superrrrr-uncomfy-021601714.html" class="stretched-box line-clamp-3 text-primary">57 Photos That Aged So, So, So, So, So, So, So, So, So, So, So, So, So, SO Poorly</a></h3><div class="flex w-full flex-row items-center truncate"><div class="flex flex-row items-center"><img alt="" loading="lazy" width="20" height="20" decoding="async" data-nimg="1" class="mr-1.5 inline size-5 rounded-full" style="color:transparent" src="https://s.yimg.com/uu/api/res/1.2/4U2KP7MS0ohHTsNvYgky2Q--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2021-06/0c895a10-d5bf-11eb-9eff-ff3e6357acd9.cf.webp"/><span class="truncate whitespace-nowrap label-m-regular text-tertiary">BuzzFeed</span></div></div></div></div><div class="relative hidden md:flex"><div class="relative shrink-0 overflow-hidden mr-3 size-[110px] rounded-lg lg:mr-3 lg:size-[80px]"><img alt="" loading="lazy" width="0" height="0" decoding="async" data-nimg="1" class="size-full object-cover" style="color:transparent" src="https://s.yimg.com/uu/api/res/1.2/.uNfN3yD0TMYVKPWGoVeFw--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/the_telegraph_818/29e5978fef680512b856a67ff4f1b564.cf.webp"/></div><div><h3 class="mb-1.5 text-[1.0625rem] font-semibold lg:text-[0.9375rem] lg:leading-[1.1875rem]"><a data-ylk="ct:story;elm:hdln;g:31887d7d-ecff-3841-9141-5c6f8bb380da;itc:0;sec:trending-story-center;ll3:target-deeplink;" href="https://uk.news.yahoo.com/teen-sex-sensation-euphoria-became-120000234.html" class="stretched-box line-clamp-3 text-primary">How teen sex sensation Euphoria became TV’s most toxic drama</a></h3><div class="flex w-full flex-row items-center truncate"><div class="flex flex-row items-center"><img alt="" loading="lazy" width="20" height="20" decoding="async" data-nimg="1" class="mr-1.5 inline size-5 rounded-full" style="color:transparent" src="https://s.yimg.com/uu/api/res/1.2/evdCb7D3yjHiwa.yKap8Ng--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2020-12/10a3d5f0-338d-11eb-beff-c4bb85ecc680.cf.webp"/><span class="truncate whitespace-nowrap label-m-regular text-tertiary">The Telegraph</span></div></div></div></div></div></div></div><p class="mb-4 text-lg md:leading-8 break-words">“Then we go to <a href="https://uk.movies.yahoo.com/tagged/leonardo-dicaprio" data-ylk="slk:Leonardo [DiCaprio];elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Leonardo [DiCaprio]&quot;}" class="link ">Leonardo [DiCaprio]</a>. He says yes, we have meetings with him and then he goes, 'you know, I can't go do another visual effects movie having just finished<em> Titanic'</em>, and he drops out.”</p><p class="mb-4 text-lg md:leading-8 break-words"><strong>Read More: </strong><a href="https://uk.movies.yahoo.com/marvel-in-talks-with-keanu-reeves-to-join-angelina-jolieled-the-eternals-movie-110046153.html" data-ylk="slk:Keanu Reeves in talks to join Marvel’s The Eternals;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Keanu Reeves in talks to join Marvel’s The Eternals&quot;}" class="link  yahoo-link"><strong>Keanu Reeves in talks to join Marvel’s </strong><em><strong>The Eternals</strong></em></a></p><div class="max-md:faux-bleed mb-4 bg-marshmallow pb-5 dark:bg-ramones md:invisible md:mb-0 md:h-0 md:overflow-hidden md:pb-0"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_5cn58qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_5cn58qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_5cn58qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (max-width: 767.95px) {
        #_R_5cn58qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><div class="mb-4 hidden pb-5 md:block"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_9cn58qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_9cn58qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_9cn58qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (min-width: 768px) {
        #_R_9cn58qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><p class="mb-4 text-lg md:leading-8 break-words">This is some list of names, and we haven't even entered into the rumour mill yet. Though when doing so, another incredible collection of actors who supposedly rejected the role, or at least were considered, takes shape. Firstly there is <a href="https://uk.movies.yahoo.com/tagged/johnny-depp" data-ylk="slk:Johnny Depp;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Johnny Depp&quot;}" class="link ">Johnny Depp</a>, who apparently passed on the role, just like he did with Speed. Keanu Reeves accidentally owes a lot to this man.</p><figure class="relative mb-4"><div class="relative"><img alt="LOS ANGELES, CALIFORNIA - JULY 10: Sandra Bullock speaks onstage during The 2019 ESPYs at Microsoft Theater on July 10, 2019 in Los Angeles, California. (Photo by Kevin Winter/Getty Images)" loading="lazy" width="960" height="691" decoding="async" data-nimg="1" class="rounded-lg" style="color:transparent" src="https://s.yimg.com/ny/api/res/1.2/7aJA9fi9SgNGnFHCNL9fkw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTY5MTtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/3452d3b0-a4b5-11e9-87b8-0791fd1b8fb9"/><button aria-label="View larger image" class="group absolute bottom-0 size-full" data-ylk="elm:expand;itc:1;sec:image-lightbox;slk:lightbox-open;"><span class="absolute bottom-3 right-3 rounded-full bg-white p-3 opacity-100 shadow-elevation-3 transition-opacity duration-300 group-hover:block group-hover:opacity-100 md:p-[17px] lg:bottom-6 lg:right-6 lg:bg-white/90 lg:p-5 lg:opacity-0 lg:shadow-none"><svg viewBox="0 0 22 22" aria-hidden="true" class="size-4 lg:size-6" width="22" height="22"><path d="M12.372.92c0-.506.41-.916.915-.916L21 0l-.004 7.712a.917.917 0 0 1-1.832 0V3.183l-6.827 6.828-1.349-1.348 6.828-6.828h-4.529a.915.915 0 0 1-.915-.915M1.835 17.816l6.828-6.828 1.349 1.349-6.829 6.827h4.529a.915.915 0 0 1 0 1.831L0 21l.004-7.713a.916.916 0 0 1 1.831 0z"></path></svg></span></button><dialog aria-label="Modal dialogue" aria-modal="true" class="fixed bottom-0 left-0 right-0 top-0 z-4 size-full max-h-none max-w-none bg-white hidden"></dialog></div><figcaption class="relative text-sm mt-1 pr-2.5"><div style="max-height:none;overflow:visible">Another contender: Sandra Bullock speaks onstage during The 2019 ESPYs (Photo by Kevin Winter/Getty Images)</div></figcaption></figure><p class="mb-4 text-lg md:leading-8 break-words"><a href="https://uk.movies.yahoo.com/tagged/kevin-costner" data-ylk="slk:Kevin Costner;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Kevin Costner&quot;}" class="link ">Kevin Costner</a>, <a href="https://uk.movies.yahoo.com/tagged/tom-cruise" data-ylk="slk:Tom Cruise;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Tom Cruise&quot;}" class="link ">Tom Cruise</a>, David Duchovny and Brandon Lee were supposedly all in the mix too, which makes you wonder just how low down on the pecking order Reeves was. But he's had the last laugh. Don't worry Keanu, we all think you're excellent.</p><p class="mb-4 text-lg md:leading-8 break-words">This is just Neo we’re analysing too, how about the fact that <a href="https://uk.movies.yahoo.com/tagged/gary-oldman" data-ylk="slk:Gary Oldman;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Gary Oldman&quot;}" class="link ">Gary Oldman</a>, <a href="https://uk.movies.yahoo.com/tagged/samuel-l-jackson" data-ylk="slk:Samuel L. Jackson;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Samuel L. Jackson&quot;}" class="link ">Samuel L. Jackson</a>, Val Kilmer and <a href="https://uk.movies.yahoo.com/tagged/russell-crowe" data-ylk="slk:Russell Crowe;elm:context_link;itc:0;sec:content-canvas" data-yga="{&quot;yLinkElement&quot;:&quot;context_link&quot;,&quot;yModuleName&quot;:&quot;content-canvas&quot;,&quot;yLinkText&quot;:&quot;Russell Crowe&quot;}" class="link ">Russell Crowe</a> were all said to have been approached for the part of Morpheus – which of course went to Laurence Fishburne, while Hugo Weaving's Agent Smith was initially offered to Jean Reno (who turned down the part because he said he couldn't leave France for such a long period of time to shoot the movie).</p><figure class="relative mb-4"><div class="relative"><img alt="Another role that could&#x27;ve gone elsewhere - but Morpheus is Laurence Fishburne" loading="lazy" width="960" height="540" decoding="async" data-nimg="1" class="rounded-lg" style="color:transparent" src="https://s.yimg.com/ny/api/res/1.2/ZnoXemNjd41PvZfE8WSEBA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MDtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/66059af0-a4b5-11e9-bffe-2a3013d13917"/><button aria-label="View larger image" class="group absolute bottom-0 size-full" data-ylk="elm:expand;itc:1;sec:image-lightbox;slk:lightbox-open;"><span class="absolute bottom-3 right-3 rounded-full bg-white p-3 opacity-100 shadow-elevation-3 transition-opacity duration-300 group-hover:block group-hover:opacity-100 md:p-[17px] lg:bottom-6 lg:right-6 lg:bg-white/90 lg:p-5 lg:opacity-0 lg:shadow-none"><svg viewBox="0 0 22 22" aria-hidden="true" class="size-4 lg:size-6" width="22" height="22"><path d="M12.372.92c0-.506.41-.916.915-.916L21 0l-.004 7.712a.917.917 0 0 1-1.832 0V3.183l-6.827 6.828-1.349-1.348 6.828-6.828h-4.529a.915.915 0 0 1-.915-.915M1.835 17.816l6.828-6.828 1.349 1.349-6.829 6.827h4.529a.915.915 0 0 1 0 1.831L0 21l.004-7.713a.916.916 0 0 1 1.831 0z"></path></svg></span></button><dialog aria-label="Modal dialogue" aria-modal="true" class="fixed bottom-0 left-0 right-0 top-0 z-4 size-full max-h-none max-w-none bg-white hidden"></dialog></div><figcaption class="relative text-sm mt-1 pr-2.5"><div style="max-height:none;overflow:visible">Another role that could've gone elsewhere - but Morpheus is Laurence Fishburne</div></figcaption></figure><p class="mb-4 text-lg md:leading-8 break-words">Then there's Sean Connery, who was said to have turned down the role of the Architect who appears in the film sequels (apparently because he found it all too confusing), while Janet Jackson was approached to play Trinity, which of course went to Carrie-Anne Moss. There was also another potential gender reversal on the cards when Michelle Yeoh was asked to play Seraph, but she too said no – as did Jet Li. The role eventually went to Collin Chou. Finally the role of Zee – played by Nona Gaye, is one that once belonged to Aaliyah, before the musician tragically died in a plane crash.</p><div class="max-md:faux-bleed mb-4 bg-marshmallow pb-5 dark:bg-ramones md:invisible md:mb-0 md:h-0 md:overflow-hidden md:pb-0"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_5g758qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_5g758qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_5g758qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (max-width: 767.95px) {
        #_R_5g758qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><div class="mb-4 hidden pb-5 md:block"><div class="py-2 text-center text-xs uppercase">Advertisement</div><div class="flex w-full flex-nowrap justify-center"><div class="flex ad-container" id="_R_9g758qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_9g758qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_9g758qoqk5elubsnqq5bH1_ { display: none; }
@media screen and (min-width: 768px) {
        #_R_9g758qoqk5elubsnqq5bH1_ { display: flex; }
        iframe { max-width: 100vw; }
      }</style></div></div></div><p class="mb-4 text-lg md:leading-8 break-words">So while we've focused on the ever-changing face of Neo, there's a whole other feature for a whole other day that could be written on the talented bunch who rejected the key supporting roles too. Maybe we'll save that one for the 30th anniversary.</p><p class="mb-4 text-lg md:leading-8 break-words"><em><strong>The Matrix </strong></em><strong>has been re-released in 4K and is back in cinemas now. Cineworld is also showing the film in the immersive 4DX format for the first time ever.</strong></p><div class="mb-4"><div class="rounded-lg chromatic-ignore relative overflow-hidden bg-black aspect-[16/9]"></div></div></div><div class="mt-2"></div></div></div></div><aside class="col-aside hidden h-full flex-col md:flex"><div class="flex size-full flex-col flex-nowrap"><div class="flex-auto" style="margin-top:0"><div class="sticky top-[90px] ad-container" id="_R_6p8qoqk5elubsnqq5bH1_"><div class="hidden" id="_R_6p8qoqk5elubsnqq5b_"></div><div class="flex size-full items-center justify-center text-center leading-3 bg-marshmallow dark:bg-ramones dark:text-grey-hair" style="height:250px;width:300px">Advertisement</div><style type="text/css">#_R_6p8qoqk5elubsnqq5bH1_ { display: none; }
