g\":{\"totalCount\":0,\"formattedStartTime\":{}},\"seoMeta\":{\"appLinks\":{\"al:android:app_name\":\"Yahoo\",\"al:android:package\":\"com.yahoo.mobile.client.android.yahoo\",\"al:ios:app_name\":\"Yahoo\",\"al:ios:app_store_id\":\"304158842\"},\"twitterTags\":{\"twitter:site\":\"@Yahoo\",\"twitter:dnt\":\"on\"},\"ogTags\":{\"og:type\":\"article\"},\"canonicalUrl\":\"https://uk.movies.yahoo.com/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo-150940004.html\",\"nativeUrl\":\"yahoo://article/view?uuid=53a8586b-452f-3ec1-b454-abbe11255798\u0026src=web\",\"seoTitle\":\"Keanu Reeves is Neo in The Matrix - but turns out he was low down on the list\",\"searchNoIndex\":false,\"title\":\"'The Matrix' at 20: The actors who turned down the role of Neo\",\"subheadline\":\"\",\"socialHeadline\":\"\",\"keywords\":\"Keanu Reeves, Wachowski, Nicolas Cage, Will Smith, leading role, Wild Wild West, Matrix film, Sandra Bullock, The Matrix, Agent Smith, Lorenzo di Bonaventura\",\"providerContentUrl\":\"https://www.yahoo.com/entry/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo_n_5d286a79e4b02a5a5d5937aa\",\"previewLink\":null,\"clickThroughUrl\":\"https://uk.movies.yahoo.com/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo-150940004.html\",\"homepageUrl\":\"https://uk.movies.yahoo.com/movies/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo-150940004.html\",\"seamlessUrl\":\"https://uk.movies.yahoo.com/movies/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo-150940004.html\"},\"siteSections\":{\"sectionItems\":[],\"sectionContentCategoryPath\":\"\"},\"secondaryTypes\":[],\"storyAtoms\":[{\"type\":\"text\",\"content\":\"20 years on from the release of \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/the-matrix\\\" data-ylk=\\\"slk:The Matrix;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;The Matrix\u0026quot;}\\\" class=\\\"link \\\"\u003e\u003cem\u003eThe Matrix\u003c/em\u003e\u003c/a\u003e\u003cem\u003e,\u003c/em\u003e and this iconic, seminal classic from the \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/the-wachowskis\\\" data-ylk=\\\"slk:Wachowski siblings;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Wachowski siblings\u0026quot;}\\\" class=\\\"link \\\"\u003eWachowski siblings \u003c/a\u003ehas left a cinematic imprint that has transcended generations – a luminary cinematic event that has left its mark on pop culture, and on the genre it sits within.\",\"length\":267,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"Naturally, when dealing with a film of this nature it's impossible to imagine anybody else playing the leading role, which of course eventually fell into the lap of everybody's \u003ca href=\\\"https://uk.movies.yahoo.com/fans-want-keanu-reeves-to-be-named-times-person-of-the-year-130235083.html\\\" data-ylk=\\\"slk:current favourite actor Keanu Reeves;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;current favourite actor Keanu Reeves\u0026quot;}\\\" class=\\\"link  yahoo-link\\\"\u003ecurrent favourite actor Keanu Reeves\u003c/a\u003e. Though we weren't far away from having to imagine a different Neo, as the list of actors – and actresses - who almost signed up to this project is quite remarkable.\",\"length\":379,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"$3d\",\"length\":345,\"tagName\":\"p\"},{\"id\":\"hm2szuXKgL8\",\"subtype\":\"videoIframe\",\"allowFullScreen\":\"false\",\"type\":\"youtube\",\"url\":\"https://www.youtube.com/embed/hm2szuXKgL8\",\"width\":1280,\"height\":720,\"scrolling\":\"no\",\"anchorId\":\"516cc65f-cdd9-5771-b084-23a29e12d281\"},{\"type\":\"text\",\"content\":\"During \u003ca href=\\\"https://www.youtube.com/watch?v=hm2szuXKgL8\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" data-ylk=\\\"slk:a video the actor posted online,;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;a video the actor posted online,\u0026quot;}\\\" class=\\\"link \\\"\u003ea video the actor posted online,\u003c/a\u003e he explained why he made the call that he did. “The Wachowskis came in and they had only done one movie,” Smith said. “They came in and made a pitch for \u003cem\u003eThe Matrix. \u003c/em\u003eAs it turns out, they're geniuses. But there's a fine line in a pitch meeting between genius, and what I experienced in the meeting.”\",\"length\":338,\"tagName\":\"p\"},{\"locationNumber\":1,\"subtype\":\"in-body\",\"type\":\"ad\"},{\"type\":\"text\",\"content\":\"Part of what makes\u003cem\u003e The Matrix\u003c/em\u003e so memorable is the bullet time effect, which Smith jokingly admits sounded like a strange idea when pitched to him at the time.\",\"length\":158,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"\u003cstrong\u003eRead More: \u003c/strong\u003e\u003ca href=\\\"https://uk.movies.yahoo.com/wachowskis-working-fourth-matrix-film-claims-john-wick-3-director-chad-stahelski-exclusive-122500310.html\\\" data-ylk=\\\"slk:The Wachowskis are working on a fourth Matrix film;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;The Wachowskis are working on a fourth Matrix film\u0026quot;}\\\" class=\\\"link  yahoo-link\\\"\u003e\u003cstrong\u003eThe Wachowskis are working on a fourth Matrix film\u003c/strong\u003e\u003c/a\u003e\",\"length\":61,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"“This is the actual pitch they made. 'We're thinking like, imagine you're in a fight. You jump, but imagine if you could stop jumping in the middle of the jump. But then people could see around you 360 while you stop jumping. We're going to invent these cameras and then people can see the whole jump when you stop in the middle of the jump.' So I made Wild Wild West. I'm not proud of it.”\",\"length\":390,\"tagName\":\"p\"},{\"type\":\"image\",\"alt\":\"Keanu Reeves is Neo, and it's hard to imagine anyone else in the role (WarnerBros)\",\"displaySize\":\"\",\"headline\":null,\"caption\":\"Keanu Reeves is Neo, and it's hard to imagine anyone else in the role (WarnerBros)\",\"credit\":null,\"className\":\"\",\"disableSlideshowImg\":false,\"size\":{\"original\":{\"width\":1349,\"height\":887,\"url\":\"https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/6f238c60-a4b4-11e9-9b77-d71880602bcd\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/woxXPxZbCi4FYxdWwqxhcg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTYzMTtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/6f238c60-a4b4-11e9-9b77-d71880602bcd\",\"width\":960,\"height\":631},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/qqfgu6_GbSDuRvIIgWNsRQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTI0MDA7aD0xNTc4O2NmPXdlYnA-/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/6f238c60-a4b4-11e9-9b77-d71880602bcd\",\"width\":1200,\"height\":789}}},{\"type\":\"text\",\"content\":\"He did, however, see a bright side in his decision. “If I had done it, because I'm black then Morpheus wouldn't have been black 'cause they were looking at \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/val-kilmer\\\" data-ylk=\\\"slk:Val Kilmer;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Val Kilmer\u0026quot;}\\\" class=\\\"link \\\"\u003eVal Kilmer\u003c/a\u003e. So I probably would've messed \u003cem\u003eThe Matrix\u003c/em\u003e up, I would have ruined it. I did you a favour.”\",\"length\":257,\"tagName\":\"p\"},{\"locationNumber\":2,\"subtype\":\"in-body\",\"type\":\"ad\"},{\"type\":\"text\",\"content\":\"So, when the Wachowskis missed out on their man it wasn't an instant decision to then pursue Reeves. No, the role was turned down by \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/nicolas-cage\\\" data-ylk=\\\"slk:Nicolas Cage;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Nicolas Cage\u0026quot;}\\\" class=\\\"link \\\"\u003eNicolas Cage\u003c/a\u003e too. His reasons were more logistical.\",\"length\":184,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"“There was a couple of movies that I was offered, but I had good reasons so couldn't do it,” \u003ca href=\\\"http://www.mtv.com/news/2429509/how-nicolas-cage-nearly-starred-in-the-matrix-and-lord-of-the-rings/\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" data-ylk=\\\"slk:Cage told MTV;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Cage told MTV\u0026quot;}\\\" class=\\\"link \\\"\u003eCage told MTV\u003c/a\u003e. “One was \u003cem\u003eThe Matrix,\u003c/em\u003e and \u003cem\u003eThe Lord of the Rings. \u003c/em\u003eBoth are great movies, but they were shot in New Zealand for great quantities of time, I mean years. Well, Australia was\u003cem\u003e The Matrix. \u003c/em\u003eBut I had family obligations, so I'm glad I stayed and I had those experiences with my family,” he finished.\",\"length\":397,\"tagName\":\"p\"},{\"type\":\"image\",\"alt\":\"US actor Nicolas Cage speaks during a press conference for his new movie \u0026quot;Jiu Jitsu\u0026quot; in the Cypriot capital Nicosia on June 29, 2019. - The movie is currently being filmed in Cyprus. (Photo by Iakovos Hatzistavrou / AFP)        (Photo credit should read IAKOVOS HATZISTAVROU/AFP/Getty Images)\",\"displaySize\":\"\",\"headline\":null,\"caption\":\"It could've been Cage. (Photo by IAKOVOS HATZISTAVROU/AFP/Getty Images)\",\"credit\":null,\"className\":\"\",\"disableSlideshowImg\":false,\"size\":{\"original\":{\"width\":6016,\"height\":4016,\"url\":\"https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/01335d10-a4b5-11e9-bbff-4093a44cfdb9\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/P5SJrW0EWYGhD53a7lvMxQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTY0MTtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/01335d10-a4b5-11e9-bbff-4093a44cfdb9\",\"width\":960,\"height\":641},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/28diYyAQwdn4QOgWLI1N6Q--/YXBwaWQ9aGlnaGxhbmRlcjt3PTI0MDA7aD0xNjAyO2NmPXdlYnA-/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/01335d10-a4b5-11e9-bbff-4093a44cfdb9\",\"width\":1200,\"height\":801}}},{\"type\":\"text\",\"content\":\"It was at this point esteemed producer Lorenzo di Bonaventura, who was an exec at Warner Bros. at the time, admitted things were getting desperate. Which led them to consider changing the gender of Neo, as they offered the role to \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/sandra-bullock\\\" data-ylk=\\\"slk:Sandra Bullock;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Sandra Bullock\u0026quot;}\\\" class=\\\"link \\\"\u003eSandra Bullock\u003c/a\u003e, the co-lead in the Reeves starring thriller\u003cem\u003e Speed.\u003c/em\u003e\",\"length\":297,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"“We went to so many people I don't remember, we were getting desperate,” \u003ca href=\\\"https://www.thewrap.com/the-matrix-filmmakers-wanted-sandra-bullock-as-neo-before-keanu-reeves-took-the-role/\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" data-ylk=\\\"slk:di Bonaventura told The Wrap;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;di Bonaventura told The Wrap\u0026quot;}\\\" class=\\\"link \\\"\u003edi Bonaventura told The Wrap\u003c/a\u003e. “We went to Sandy Bullock and said we'll change Neo to a girl. Joel Silver and I worked with her on\u003cem\u003e Demolition Man\u003c/em\u003e and she continues to be a very good friend of mine. We sent her the script to see if she was interested in it and if she was we would try to make the change. It just wasn't something for her at the time, so it didn't go anywhere.”\",\"length\":448,\"tagName\":\"p\"},{\"locationNumber\":3,\"subtype\":\"in-body\",\"type\":\"ad\"},{\"type\":\"text\",\"content\":\"In this same interview, di Bonaventura admitted that there were other high-profile names he wanted to take on this seemingly unpopular role, but once again, they turned their nose up at the production.\",\"length\":201,\"tagName\":\"p\"},{\"id\":\"D4eJx-0g3Do\",\"subtype\":\"videoIframe\",\"allowFullScreen\":\"false\",\"type\":\"youtube\",\"url\":\"https://www.youtube.com/embed/D4eJx-0g3Do\",\"width\":320,\"height\":180,\"scrolling\":\"no\",\"anchorId\":\"4d3b6441-4f8c-5644-83f3-06d5e4002de2\"},{\"type\":\"text\",\"content\":\"“The first movie star who says is \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/brad-pitt\\\" data-ylk=\\\"slk:Brad Pitt,;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Brad Pitt,\u0026quot;}\\\" class=\\\"link \\\"\u003eBrad Pitt,\u003c/a\u003e he's doing \u003cem\u003eSeven Years in Tibet \u003c/em\u003eand then he's coming out of it and he's way too exhausted to take this on, so he's gone,” he said.\",\"length\":175,\"tagName\":\"p\"},{\"subtype\":\"category\",\"type\":\"recirc\",\"data\":{\"articles\":[{\"aiCommentSummary\":\"$undefined\",\"attribution\":{\"authorImage\":\"$undefined\",\"authors\":\"$undefined\",\"brandAlias\":\"$undefined\",\"brandUuid\":\"$undefined\",\"image\":{\"originalUrl\":\"https://s.yimg.com/os/creatr-uploaded-images/2024-10/de4ea600-8fba-11ef-bff7-cd35103c6400\",\"altText\":\"\",\"originalHeight\":400,\"originalWidth\":400,\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/gxuWmwglWNlOdlSoV8_SqQ--~B/aD00MDA7dz00MDA7YXBwaWQ9eXRhY2h5b24-/https://s.yimg.com/os/creatr-uploaded-images/2024-10/de4ea600-8fba-11ef-bff7-cd35103c6400.cf.webp\",\"tag\":\"original\",\"height\":400,\"width\":400},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/AOQEA9bt.uBt3y27kGTHTg--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2024-10/de4ea600-8fba-11ef-bff7-cd35103c6400.cf.webp\",\"tag\":\"x20|2|100\",\"height\":40,\"width\":40}]},\"isCreatorContent\":\"$undefined\",\"isOriginalContent\":false,\"providerBrandId\":\"$undefined\",\"providerSourceId\":\"evening_standard_239\",\"showBrandPage\":\"$undefined\",\"source\":\"Evening Standard\"},\"badges\":[{\"id\":\"ENTERTAINMENT\",\"type\":\"Category\"}],\"bypassModal\":false,\"cacheId\":\"d03849e1-dfd0-35a2-bcda-43f08cfdb36e-1775610309820\",\"categoryLabel\":\"Entertainment\",\"commentCount\":0,\"contentType\":\"STORY\",\"duration\":\"$undefined\",\"generatedSummary\":\"$undefined\",\"id\":\"d03849e1-dfd0-35a2-bcda-43f08cfdb36e\",\"instrumentation\":\"$undefined\",\"isHosted\":false,\"isLiveLabelSuppressed\":false,\"isPlutusStory\":\"$undefined\",\"liveBlog\":false,\"liveBlogId\":\"$undefined\",\"pubDate\":\"$undefined\",\"relatedPhotos\":[],\"slides\":null,\"summary\":\"Munchetty, 51, was reportedly placed under review last year over allegations of ‘bullying’ other colleagues\",\"thumbnail\":{\"originalUrl\":\"https://media.zenfs.com/en/evening_standard_239/497b8b1412b870e14142edebdda50840\",\"originalWidth\":1200,\"originalHeight\":666,\"caption\":\"\",\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/93aVwJCT4miXsnyuUa7Qrg--~B/aD02NjY7dz0xMjAwO2FwcGlkPXl0YWNoeW9u/https://media.zenfs.com/en/evening_standard_239/497b8b1412b870e14142edebdda50840.cf.webp\",\"width\":1200,\"height\":666,\"tag\":\"original\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/IjlV.ExdhLFOxxg9aY3LVg--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/evening_standard_239/497b8b1412b870e14142edebdda50840.cf.webp\",\"width\":220,\"height\":220,\"tag\":\"110x110|2|95\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/RUSKO3DqOPM0yes_MT5w9Q--~B/Zmk9c3RyaW07aD00MDA7cT05NTt3PTYyNDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/evening_standard_239/497b8b1412b870e14142edebdda50840.cf.webp\",\"width\":624,\"height\":400,\"tag\":\"312x200|2|95\"}]},\"title\":\"Revealed: Reason behind Naga Munchetty's 'sly digs' at Carol Kirkwood as star leaves BBC Breakfast\",\"type\":\"story\",\"url\":\"https://uk.news.yahoo.com/reason-behind-naga-munchettys-sly-095322240.html\",\"viewCount\":0,\"wpm200\":222},{\"aiCommentSummary\":\"$undefined\",\"attribution\":{\"authorImage\":\"$undefined\",\"authors\":\"$undefined\",\"brandAlias\":\"$undefined\",\"brandUuid\":\"$undefined\",\"image\":{\"originalUrl\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-12/6bd69e40-33fa-11eb-abd9-983cb1867d1e\",\"altText\":\"\",\"originalHeight\":400,\"originalWidth\":400,\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/37hynOF8B9rCStG.AAtPsw--~B/aD00MDA7dz00MDA7YXBwaWQ9eXRhY2h5b24-/https://s.yimg.com/os/creatr-uploaded-images/2020-12/6bd69e40-33fa-11eb-abd9-983cb1867d1e.cf.webp\",\"tag\":\"original\",\"height\":400,\"width\":400},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/y4I8zkHJDIdObDFlHu86hQ--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2020-12/6bd69e40-33fa-11eb-abd9-983cb1867d1e.cf.webp\",\"tag\":\"x20|2|100\",\"height\":40,\"width\":40}]},\"isCreatorContent\":\"$undefined\",\"isOriginalContent\":false,\"providerBrandId\":\"$undefined\",\"providerSourceId\":\"digital_spy_281\",\"showBrandPage\":\"$undefined\",\"source\":\"Digital Spy\"},\"badges\":[{\"id\":\"ENTERTAINMENT\",\"type\":\"Category\"}],\"bypassModal\":false,\"cacheId\":\"423bfc90-4bb0-3336-bff3-44c179b3f4ec-1775610309820\",\"categoryLabel\":\"Entertainment\",\"commentCount\":0,\"contentType\":\"STORY\",\"duration\":\"$undefined\",\"generatedSummary\":\"$undefined\",\"id\":\"423bfc90-4bb0-3336-bff3-44c179b3f4ec\",\"instrumentation\":\"$undefined\",\"isHosted\":false,\"isLiveLabelSuppressed\":false,\"isPlutusStory\":\"$undefined\",\"liveBlog\":false,\"liveBlogId\":\"$undefined\",\"pubDate\":\"$undefined\",\"relatedPhotos\":[],\"slides\":null,\"summary\":\"Could it happen?\",\"thumbnail\":{\"originalUrl\":\"https://media.zenfs.com/en/digital_spy_281/c9bd14eaa2b6e95c0b7da134f60cd372\",\"originalWidth\":1440,\"originalHeight\":723,\"caption\":\"michelle dockery, arty froushan, dominic west, downton abbey: the grand finale\",\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/ztUc3oHw46xHDE_pWV5oTg--~B/aD03MjM7dz0xNDQwO2FwcGlkPXl0YWNoeW9u/https://media.zenfs.com/en/digital_spy_281/c9bd14eaa2b6e95c0b7da134f60cd372.cf.webp\",\"width\":1440,\"height\":723,\"tag\":\"original\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/zFkD3zywfdCxWekPvGEGiw--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/digital_spy_281/c9bd14eaa2b6e95c0b7da134f60cd372.cf.webp\",\"width\":220,\"height\":220,\"tag\":\"110x110|2|95\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/ixaqB1W.LrhazxcbeUUx6g--~B/Zmk9c3RyaW07aD00MDA7cT05NTt3PTYyNDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/digital_spy_281/c9bd14eaa2b6e95c0b7da134f60cd372.cf.webp\",\"width\":624,\"height\":400,\"tag\":\"312x200|2|95\"}]},\"title\":\"Downton Abbey star backed to replace Daniel Craig as the next James Bond\",\"type\":\"story\",\"url\":\"https://uk.movies.yahoo.com/downton-abbey-star-backed-replace-160000975.html\",\"viewCount\":0,\"wpm200\":124},{\"aiCommentSummary\":\"$undefined\",\"attribution\":{\"authorImage\":\"$undefined\",\"authors\":\"$undefined\",\"brandAlias\":\"$undefined\",\"brandUuid\":\"$undefined\",\"image\":{\"originalUrl\":\"https://s.yimg.com/os/creatr-uploaded-images/2021-06/0c895a10-d5bf-11eb-9eff-ff3e6357acd9\",\"altText\":\"\",\"originalHeight\":400,\"originalWidth\":400,\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/eNstMbCetoOvSSN2yt43fg--~B/aD00MDA7dz00MDA7YXBwaWQ9eXRhY2h5b24-/https://s.yimg.com/os/creatr-uploaded-images/2021-06/0c895a10-d5bf-11eb-9eff-ff3e6357acd9.cf.webp\",\"tag\":\"original\",\"height\":400,\"width\":400},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/4U2KP7MS0ohHTsNvYgky2Q--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2021-06/0c895a10-d5bf-11eb-9eff-ff3e6357acd9.cf.webp\",\"tag\":\"x20|2|100\",\"height\":40,\"width\":40}]},\"isCreatorContent\":\"$undefined\",\"isOriginalContent\":false,\"providerBrandId\":\"$undefined\",\"providerSourceId\":\"buzzfeed_articles_778\",\"showBrandPage\":\"$undefined\",\"source\":\"BuzzFeed\"},\"badges\":[{\"id\":\"ENTERTAINMENT\",\"type\":\"Category\"}],\"bypassModal\":false,\"cacheId\":\"c81dcc9f-ef85-3948-8103-06c3008c0b88-1775610309820\",\"categoryLabel\":\"Entertainment\",\"commentCount\":0,\"contentType\":\"STORY\",\"duration\":\"$undefined\",\"generatedSummary\":\"$undefined\",\"id\":\"c81dcc9f-ef85-3948-8103-06c3008c0b88\",\"instrumentation\":\"$undefined\",\"isHosted\":false,\"isLiveLabelSuppressed\":false,\"isPlutusStory\":\"$undefined\",\"liveBlog\":false,\"liveBlogId\":\"$undefined\",\"pubDate\":\"$undefined\",\"relatedPhotos\":[],\"slides\":null,\"summary\":\"\\\"I know nothing about Kanye...other than I do hate his song 'Gold Digger.' That's all. He'll be a nobody in a couple years.\\\"\",\"thumbnail\":{\"originalUrl\":\"https://media.zenfs.com/en/buzzfeed_articles_778/93491b1788b4cb08ec71c9db3d369108\",\"originalWidth\":1250,\"originalHeight\":830,\"caption\":\"\",\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/NZ1PrkynwAkH4QwgQ8jUnw--~B/aD04MzA7dz0xMjUwO2FwcGlkPXl0YWNoeW9u/https://media.zenfs.com/en/buzzfeed_articles_778/93491b1788b4cb08ec71c9db3d369108.cf.webp\",\"width\":1250,\"height\":830,\"tag\":\"original\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/fCutyUvL315q_Nq3pYlwbA--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/buzzfeed_articles_778/93491b1788b4cb08ec71c9db3d369108.cf.webp\",\"width\":220,\"height\":220,\"tag\":\"110x110|2|95\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/eIGZCqIBrh0iXOGE6GArFA--~B/Zmk9c3RyaW07aD00MDA7cT05NTt3PTYyNDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/buzzfeed_articles_778/93491b1788b4cb08ec71c9db3d369108.cf.webp\",\"width\":624,\"height\":400,\"tag\":\"312x200|2|95\"}]},\"title\":\"57 Photos That Aged So, So, So, So, So, So, So, So, So, So, So, So, So, SO Poorly\",\"type\":\"story\",\"url\":\"https://uk.news.yahoo.com/57-photos-made-superrrrr-uncomfy-021601714.html\",\"viewCount\":0,\"wpm200\":363},{\"aiCommentSummary\":\"$undefined\",\"attribution\":{\"authorImage\":\"$undefined\",\"authors\":\"$undefined\",\"brandAlias\":\"$undefined\",\"brandUuid\":\"$undefined\",\"image\":{\"originalUrl\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-12/10a3d5f0-338d-11eb-beff-c4bb85ecc680\",\"altText\":\"\",\"originalHeight\":400,\"originalWidth\":400,\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/XRXiOO3t0DK8.8N9aAm2wg--~B/aD00MDA7dz00MDA7YXBwaWQ9eXRhY2h5b24-/https://s.yimg.com/os/creatr-uploaded-images/2020-12/10a3d5f0-338d-11eb-beff-c4bb85ecc680.cf.webp\",\"tag\":\"original\",\"height\":400,\"width\":400},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/evdCb7D3yjHiwa.yKap8Ng--~B/Zmk9ZmlsbDtoPTQwO3B5b2ZmPTA7cT0xMDA7dz00MDthcHBpZD15dGFjaHlvbg--/https://s.yimg.com/os/creatr-uploaded-images/2020-12/10a3d5f0-338d-11eb-beff-c4bb85ecc680.cf.webp\",\"tag\":\"x20|2|100\",\"height\":40,\"width\":40}]},\"isCreatorContent\":\"$undefined\",\"isOriginalContent\":false,\"providerBrandId\":\"$undefined\",\"providerSourceId\":\"the_telegraph_818\",\"showBrandPage\":\"$undefined\",\"source\":\"The Telegraph\"},\"badges\":[{\"id\":\"ENTERTAINMENT\",\"type\":\"Category\"}],\"bypassModal\":false,\"cacheId\":\"31887d7d-ecff-3841-9141-5c6f8bb380da-1775610309820\",\"categoryLabel\":\"Entertainment\",\"commentCount\":0,\"contentType\":\"STORY\",\"duration\":\"$undefined\",\"generatedSummary\":\"$undefined\",\"id\":\"31887d7d-ecff-3841-9141-5c6f8bb380da\",\"instrumentation\":\"$undefined\",\"isHosted\":false,\"isLiveLabelSuppressed\":false,\"isPlutusStory\":\"$undefined\",\"liveBlog\":false,\"liveBlogId\":\"$undefined\",\"pubDate\":\"$undefined\",\"relatedPhotos\":[],\"slides\":null,\"summary\":\"Even the Harry Potter franchise hasn’t been dogged by quite as many controversies as HBO’s Euphoria. The hit X-rated drama about nihilistic, drug-addled teenagers in modern-day Los Angeles returns for its years-delayed third season this month after much speculation that it wouldn’t – and shouldn’t – come back at all. For its breakout superstars Zendaya, Sydney Sweeney and Jacob Elordi, Euphoria is their poisoned chalice: it single-handedly launched their careers, and has tormented them ever sinc\",\"thumbnail\":{\"originalUrl\":\"https://media.zenfs.com/en/the_telegraph_818/29e5978fef680512b856a67ff4f1b564\",\"originalWidth\":1747,\"originalHeight\":1092,\"caption\":\"Sydney Sweeney in season 3 of Euphoria\",\"resolutions\":[{\"url\":\"https://s.yimg.com/uu/api/res/1.2/TCq_KJ5uZS.ewXdLEHOtlQ--~B/aD0xMDkyO3c9MTc0NzthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/the_telegraph_818/29e5978fef680512b856a67ff4f1b564.cf.webp\",\"width\":1747,\"height\":1092,\"tag\":\"original\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/.uNfN3yD0TMYVKPWGoVeFw--~B/Zmk9c3RyaW07aD0yMjA7cT05NTt3PTIyMDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/the_telegraph_818/29e5978fef680512b856a67ff4f1b564.cf.webp\",\"width\":220,\"height\":220,\"tag\":\"110x110|2|95\"},{\"url\":\"https://s.yimg.com/uu/api/res/1.2/X2OKA0NiCueHQ4Q.r8sA3Q--~B/Zmk9c3RyaW07aD00MDA7cT05NTt3PTYyNDthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/en/the_telegraph_818/29e5978fef680512b856a67ff4f1b564.cf.webp\",\"width\":624,\"height\":400,\"tag\":\"312x200|2|95\"}]},\"title\":\"How teen sex sensation Euphoria became TV’s most toxic drama\",\"type\":\"story\",\"url\":\"https://uk.news.yahoo.com/teen-sex-sensation-euphoria-became-120000234.html\",\"viewCount\":0,\"wpm200\":669}]}},{\"type\":\"text\",\"content\":\"“Then we go to \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/leonardo-dicaprio\\\" data-ylk=\\\"slk:Leonardo [DiCaprio];elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Leonardo [DiCaprio]\u0026quot;}\\\" class=\\\"link \\\"\u003eLeonardo [DiCaprio]\u003c/a\u003e. He says yes, we have meetings with him and then he goes, 'you know, I can't go do another visual effects movie having just finished\u003cem\u003e Titanic'\u003c/em\u003e, and he drops out.”\",\"length\":196,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"\u003cstrong\u003eRead More: \u003c/strong\u003e\u003ca href=\\\"https://uk.movies.yahoo.com/marvel-in-talks-with-keanu-reeves-to-join-angelina-jolieled-the-eternals-movie-110046153.html\\\" data-ylk=\\\"slk:Keanu Reeves in talks to join Marvel’s The Eternals;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Keanu Reeves in talks to join Marvel’s The Eternals\u0026quot;}\\\" class=\\\"link  yahoo-link\\\"\u003e\u003cstrong\u003eKeanu Reeves in talks to join Marvel’s \u003c/strong\u003e\u003cem\u003e\u003cstrong\u003eThe Eternals\u003c/strong\u003e\u003c/em\u003e\u003c/a\u003e\",\"length\":62,\"tagName\":\"p\"},{\"locationNumber\":4,\"subtype\":\"in-body\",\"type\":\"ad\"},{\"type\":\"text\",\"content\":\"This is some list of names, and we haven't even entered into the rumour mill yet. Though when doing so, another incredible collection of actors who supposedly rejected the role, or at least were considered, takes shape. Firstly there is \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/johnny-depp\\\" data-ylk=\\\"slk:Johnny Depp;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Johnny Depp\u0026quot;}\\\" class=\\\"link \\\"\u003eJohnny Depp\u003c/a\u003e, who apparently passed on the role, just like he did with Speed. Keanu Reeves accidentally owes a lot to this man.\",\"length\":363,\"tagName\":\"p\"},{\"type\":\"image\",\"alt\":\"LOS ANGELES, CALIFORNIA - JULY 10: Sandra Bullock speaks onstage during The 2019 ESPYs at Microsoft Theater on July 10, 2019 in Los Angeles, California. (Photo by Kevin Winter/Getty Images)\",\"displaySize\":\"\",\"headline\":null,\"caption\":\"Another contender: Sandra Bullock speaks onstage during The 2019 ESPYs (Photo by Kevin Winter/Getty Images)\",\"credit\":null,\"className\":\"\",\"disableSlideshowImg\":false,\"size\":{\"original\":{\"width\":4000,\"height\":2880,\"url\":\"https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/3452d3b0-a4b5-11e9-87b8-0791fd1b8fb9\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/7aJA9fi9SgNGnFHCNL9fkw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTY5MTtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/3452d3b0-a4b5-11e9-87b8-0791fd1b8fb9\",\"width\":960,\"height\":691},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/hVMQh3aORvwVyTwdZazNrQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTI0MDA7aD0xNzI4O2NmPXdlYnA-/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-images/2019-07/3452d3b0-a4b5-11e9-87b8-0791fd1b8fb9\",\"width\":1200,\"height\":864}}},{\"type\":\"text\",\"content\":\"\u003ca href=\\\"https://uk.movies.yahoo.com/tagged/kevin-costner\\\" data-ylk=\\\"slk:Kevin Costner;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Kevin Costner\u0026quot;}\\\" class=\\\"link \\\"\u003eKevin Costner\u003c/a\u003e, \u003ca href=\\\"https://uk.movies.yahoo.com/tagged/tom-cruise\\\" data-ylk=\\\"slk:Tom Cruise;elm:context_link;itc:0;sec:content-canvas\\\" data-yga=\\\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Tom Cruise\u0026quot;}\\\" class=\\\"link \\\"\u003eTom Cruise\u003c/a\u003e, David Duchovny and Brandon Lee were supposedly all in the mix too, which makes you wonder just how low down on the pecking order Reeves was. But he's had the last laugh. Don't worry Keanu, we all think you're excellent.\",\"length\":246,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"$3e\",\"length\":418,\"tagName\":\"p\"},{\"type\":\"image\",\"alt\":\"Another role that could've gone elsewhere - but Morpheus is Laurence Fishburne\",\"displaySize\":\"\",\"headline\":null,\"caption\":\"Another role that could've gone elsewhere - but Morpheus is Laurence Fishburne\",\"credit\":null,\"className\":\"\",\"disableSlideshowImg\":false,\"size\":{\"original\":{\"width\":1427,\"height\":802,\"url\":\"https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/66059af0-a4b5-11e9-bffe-2a3013d13917\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/ZnoXemNjd41PvZfE8WSEBA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MDtjZj13ZWJw/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/66059af0-a4b5-11e9-bffe-2a3013d13917\",\"width\":960,\"height\":540},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/1BHhTx7H2OvrPwHSeptOhQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTI0MDA7aD0xMzQ4O2NmPXdlYnA-/https://media-mbst-pub-ue1.s3.amazonaws.com/creatr-uploaded-images/2019-07/66059af0-a4b5-11e9-bffe-2a3013d13917\",\"width\":1200,\"height\":674}}},{\"type\":\"text\",\"content\":\"Then there's Sean Connery, who was said to have turned down the role of the Architect who appears in the film sequels (apparently because he found it all too confusing), while Janet Jackson was approached to play Trinity, which of course went to Carrie-Anne Moss. There was also another potential gender reversal on the cards when Michelle Yeoh was asked to play Seraph, but she too said no – as did Jet Li. The role eventually went to Collin Chou. Finally the role of Zee – played by Nona Gaye, is one that once belonged to Aaliyah, before the musician tragically died in a plane crash.\",\"length\":587,\"tagName\":\"p\"},{\"locationNumber\":5,\"subtype\":\"in-body\",\"type\":\"ad\"},{\"type\":\"text\",\"content\":\"So while we've focused on the ever-changing face of Neo, there's a whole other feature for a whole other day that could be written on the talented bunch who rejected the key supporting roles too. Maybe we'll save that one for the 30th anniversary.\",\"length\":247,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"\u003cem\u003e\u003cstrong\u003eThe Matrix \u003c/strong\u003e\u003c/em\u003e\u003cstrong\u003ehas been re-released in 4K and is back in cinemas now. Cineworld is also showing the film in the immersive 4DX format for the first time ever.\u003c/strong\u003e\",\"length\":153,\"tagName\":\"p\"},{\"type\":\"yvideo\",\"subtype\":\"yvideo\",\"url\":\"https://uk.movies.yahoo.com/keanu-reeves-look-back-career-173411046.html?format=embed\u0026region=GB\u0026lang=en-GB\u0026site=movies\u0026player_autoplay=0\u0026expName=y20\",\"dockable\":false,\"width\":854,\"height\":480,\"config\":{\"autoplay\":false,\"duration\":0,\"height\":480,\"lang\":\"en-GB\",\"media_id_1\":\"4fdbb501-85ff-329d-a64e-afa356fa5891\",\"pageSpaceId\":\"1197756286\",\"queryParams\":null,\"region\":\"GB\",\"site\":\"movies\",\"startScreen\":{},\"url\":\"https://uk.movies.yahoo.com/keanu-reeves-look-back-career-173411046.html?format=embed\u0026region=GB\u0026lang=en-GB\u0026site=movies\u0026player_autoplay=0\u0026expName=y20\",\"width\":854,\"thumbnail\":{\"type\":\"image\",\"size\":{\"raw\":null}},\"YVAP\":{\"accountId\":\"145\"},\"expName\":\"y20\",\"playlist\":{\"mediaItems\":[{\"id\":\"4fdbb501-85ff-329d-a64e-afa356fa5891\"}],\"videoRecommendations\":true,\"id\":\"movie-videos\"},\"videoAlias\":\"keanu-reeves-look-back-career-173411046\",\"hidePlaylist\":true,\"comscoreC4\":\"UK \u0026 IE Movies\",\"videoPosition\":\"bottom\",\"videoSchema\":{\"@context\":\"https://schema.org\",\"@type\":\"VideoObject\",\"name\":\"Keanu Reeves, a look back at his career\",\"description\":\"Keanu Reeves career has spanned more than three decades. The 54-year-old actor got his start in theater and appearing in short films. He even dabbled in TV commercials. One of his first movie roles came in the 1986 film, River’s Edge. He really had Hollywood taking notice in the 1989 bro flick, Bill \u0026 Ted’s Excellent Adventure. The cult classic led to the 1991 sequel, Bill \u0026 Ted’s Bogus Journey. Fans are super-excited for movie No. 3, Bill \u0026 Ted Face the Music, scheduled for a 2020 release.  Reeves has also had huge success as an action star. In 1994, he teamed up with Sandra Bullock in Speed. He also had major recognition as “Neo” in the Matrix trilogy, and as “John Wick” in the John Wick movie franchise. He’s even signed up for a fourth Wick flick, hitting the big screen in 2021.  Earlier this month, the actor was honored with a hand and footprint ceremony at the TCL Chinese Theatre. The event celebrated Reeves’s successful career in film. “I’ve had a pretty long career and I hope it continues,” he said.\",\"thumbnailUrl\":\"https://s.yimg.com/uu/api/res/1.2/BX4UEAWrBbsbxuSinkzvpQ--~B/aD0xMDgwO3c9MTkyMDthcHBpZD15dGFjaHlvbg--/http://d.yimg.com/hd/cp-video-transcode/creatr-uploaded-videos/2019-05/edbbd586-4915-58c1-9242-3db93418afca/54f1cff0-816e-11e9-adef-57c6cce83d22_3_0.jpg?s=9f4923432ee8012e4412194d355f4fdd\u0026c=4e75cb2b15b261f0bba48aa83242ef65\u0026a=degeneric\u0026mr=0\",\"duration\":\"PT2M20S\",\"contentUrl\":\"\",\"embedUrl\":\"https://www.yahoo.com/lifestyle/keanu-reeves-look-back-career-173411046.html?format=embed\",\"identifier\":\"4fdbb501-85ff-329d-a64e-afa356fa5891\",\"publication\":{\"@type\":\"BroadcastEvent\",\"isLiveBroadcast\":true,\"startDate\":\"2019-12-17T20:38:15Z\",\"endDate\":\"2019-12-18T08:38:15Z\"}}}}],\"videoData\":{\"videoUuids\":[\"4fdbb501-85ff-329d-a64e-afa356fa5891\"],\"videoDataByUuid\":{\"4fdbb501-85ff-329d-a64e-afa356fa5891\":{\"id\":\"4fdbb501-85ff-329d-a64e-afa356fa5891\",\"title\":\"Keanu Reeves, a look back at his career\",\"description\":\"Keanu Reeves career has spanned more than three decades. The 54-year-old actor got his start in theater and appearing in short films. He even dabbled in TV commercials. One of his first movie roles came in the 1986 film, River’s Edge. He really had Hollywood taking notice in the 1989 bro flick, Bill \u0026 Ted’s Excellent Adventure. The cult classic led to the 1991 sequel, Bill \u0026 Ted’s Bogus Journey. Fans are super-excited for movie No. 3, Bill \u0026 Ted Face the Music, scheduled for a 2020 release. \\nReeves has also had huge success as an action star. In 1994, he teamed up with Sandra Bullock in Speed. He also had major recognition as “Neo” in the Matrix trilogy, and as “John Wick” in the John Wick movie franchise. He’s even signed up for a fourth Wick flick, hitting the big screen in 2021. \\nEarlier this month, the actor was honored with a hand and footprint ceremony at the TCL Chinese Theatre. The event celebrated Reeves’s successful career in film. “I’ve had a pretty long career and I hope it continues,” he said.\",\"thumbnails\":[{\"tag\":\"original\",\"url\":\"https://s.yimg.com/uu/api/res/1.2/BX4UEAWrBbsbxuSinkzvpQ--~B/aD0xMDgwO3c9MTkyMDthcHBpZD15dGFjaHlvbg--/http://d.yimg.com/hd/cp-video-transcode/creatr-uploaded-videos/2019-05/edbbd586-4915-58c1-9242-3db93418afca/54f1cff0-816e-11e9-adef-57c6cce83d22_3_0.jpg?s=9f4923432ee8012e4412194d355f4fdd\u0026c=4e75cb2b15b261f0bba48aa83242ef65\u0026a=degeneric\u0026mr=0\",\"width\":1920,\"height\":1080},{\"tag\":\"640x360\",\"url\":\"https://s.yimg.com/uu/api/res/1.2/42WRVTGzRUNNXk9hwkwctQ--~B/Zmk9c3RyaW07aD0zNjA7dz02NDA7c209MTthcHBpZD15dGFjaHlvbg--/http://d.yimg.com/hd/cp-video-transcode/creatr-uploaded-videos/2019-05/edbbd586-4915-58c1-9242-3db93418afca/54f1cff0-816e-11e9-adef-57c6cce83d22_3_0.jpg?s=9f4923432ee8012e4412194d355f4fdd\u0026c=4e75cb2b15b261f0bba48aa83242ef65\u0026a=degeneric\u0026mr=0\",\"width\":640,\"height\":360},{\"tag\":\"original_raw\",\"url\":\"http://d.yimg.com/hd/cp-video-transcode/creatr-uploaded-videos/2019-05/edbbd586-4915-58c1-9242-3db93418afca/54f1cff0-816e-11e9-adef-57c6cce83d22_3_0.jpg?s=9f4923432ee8012e4412194d355f4fdd\u0026c=4e75cb2b15b261f0bba48aa83242ef65\u0026a=degeneric\u0026mr=0\",\"width\":1920,\"height\":1080}],\"duration\":140,\"eventEnd\":0,\"publishTime\":\"2019-12-17T20:38:15Z\",\"canonicalUrl\":\"https://www.yahoo.com/lifestyle/keanu-reeves-look-back-career-173411046.html\",\"streamingUrl\":\"https://video.media.yql.yahoo.com/v1/video/sapi/hlsstreams/4fdbb501-85ff-329d-a64e-afa356fa5891.m3u8?site=movies\u0026region=GB\u0026lang=en-GB\u0026devtype=desktop\u0026src=sapi\",\"expires\":2177452799}}}}},\"schema\":{\"default\":{\"@context\":\"http://schema.org\",\"@type\":\"NewsArticle\",\"mainEntityOfPage\":\"https://uk.movies.yahoo.com/the-matrix-at-20-the-actors-who-turned-down-the-role-of-neo-150940004.html\",\"headline\":\"'The Matrix' at 20: The actors who turned down the role of Neo\",\"datePublished\":\"2019-07-12T15:09:40.000Z\",\"dateModified\":\"2019-07-12T15:26:08.000Z\",\"keywords\":[\"Keanu Reeves\",\"Wachowski\",\"Nicolas Cage\",\"Will Smith\",\"leading role\",\"Wild Wild West\",\"Matrix film\",\"Sandra Bullock\",\"The Matrix\",\"Agent Smith\",\"Lorenzo di Bonaventura\"],\"description\":\"20 years after the release of The Matrix and we cast our eye over all of the actors who could've been Neo\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Yahoo Movies UK\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://s.yimg.com/rz/p/yahoo_movies_en-US_h_p_movies_2.png\",\"width\":346,\"height\":50},\"url\":\"https://uk.movies.yahoo.com/\"},\"author\":{\"@type\":\"Person\",\"name\":\"Stefan Pape\",\"url\":\"https://www.yahoo.com/author/stefan-pape/\",\"jobTitle\":\"Contributor\"},\"creator\":{\"@type\":\"Person\",\"name\":\"Stefan Pape\",\"url