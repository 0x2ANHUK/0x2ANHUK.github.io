446-c33e7e03c540021e.js?dpl=sha-0a2d438\",\"3181\",\"static/chunks/3181-76642a509d229623.js?dpl=sha-0a2d438\",\"6890\",\"static/chunks/6890-63009f8a6e28d533.js?dpl=sha-0a2d438\",\"2509\",\"static/chunks/2509-30c08203f20a6ccc.js?dpl=sha-0a2d438\",\"5894\",\"static/chunks/5894-b6f77267e83d5471.js?dpl=sha-0a2d438\",\"9897\",\"static/chunks/9897-27a26ec9f6b0ab9e.js?dpl=sha-0a2d438\",\"3672\",\"static/chunks/app/article/%5B...parts%5D/page-1cf20f762b0bda72.js?dpl=sha-0a2d438\"],\"TopCenterAd\"]\n"])</script><script>self.__next_f.push([1,":HD\"//ncp-gw-frontpage.media.yahoo.com\"\n:HD\"//s.yimg.com\"\n:HD\"//geo.yahoo.com\"\n:HD\"//consent.cmp.oath.com\"\n:HD\"//udc.yahoo.com\"\n:HC\"//ncp-gw-frontpage.media.yahoo.com\"\n:HC\"//s.yimg.com\"\n:HC\"//geo.yahoo.com\"\n:HC\"//consent.cmp.oath.com\"\n:HC\"//udc.yahoo.com\"\n3d:T4cc,Firstly, and most famously, Neo was \u003ca href=\"https://uk.movies.yahoo.com/will-smith-reveals-didnt-play-neo-matrix-163530775.html\" data-ylk=\"slk:turned down by Will Smith;elm:context_link;itc:0;sec:content-canvas;outcm:mb_qualified_link;_E:mb_qualified_link;ct:story;\" data-yga=\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;turned down by Will Smith\u0026quot;}\" class=\"link  yahoo-link\"\u003eturned down by Will Smith\u003c/a\u003e. The actor, who also \u003ca href=\"https://uk.movies.yahoo.com/post/133852442661/will-smith-reveals-why-he-turned-down-tarantinos\" data-ylk=\"slk:rejected the chance to work with Quentin Tarantino;elm:context_link;itc:0;sec:content-canvas\" data-yga=\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;rejected the chance to work with Quentin Tarantino\u0026quot;}\" class=\"link \"\u003erejected the chance to work with Quentin Tarantino\u003c/a\u003e and take on the eponymous lead role in \u003cem\u003eDjango Unchained\u003c/em\u003e, has admitted this decision may have been ill-judged, particularly as he instead went on to star in \u003cem\u003eWild Wild West,\u003c/em\u003e one of the biggest flops of his career.3e:T54d,This is just Neo we’re analysing too, how about the fact that \u003ca href=\"https://uk.movies.yahoo.com/tagged/gary-oldman\" data-ylk=\"slk:Gary Oldman;elm:context_link;itc:0;sec:content-canvas\" data-yga=\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Gary Oldman\u0026quot;}\" class=\"link \"\u003eGary Oldman\u003c/a\u003e, \u003ca href=\"https://uk.movies.yahoo.com/tagged/samuel-l-jackson\" data-ylk=\"slk:Samuel L. Jackson;elm:context_link;itc:0;sec:content-canvas\" data-yga=\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Samuel L. Jackson\u0026quot;}\" class=\"link \"\u003eSamuel L. Jackson\u003c/a\u003e, Val Kilmer and \u003ca href=\"https://uk.movies.yahoo.com/tagged/russell-crowe\" data-ylk=\"slk:Russell Crowe;elm:context_link;itc:0;sec:content-canvas\" data-yga=\"{\u0026quot;yLinkElement\u0026quot;:\u0026quot;context_link\u0026quot;,\u0026quot;yModuleName\u0026quot;:\u0026quot;content-canvas\u0026quot;,\u0026quot;yLinkText\u0026quot;:\u0026quot;Russell Crowe\u0026quot;}\" class=\"link \"\u003eRussell Crowe\u003c/a\u003e were all said to have been approached for the part of Morpheus – which of course went to Laurence Fishburne, while Hugo Weaving's Agent Smith was initially offered to Jean Reno (who turned down the part because he said he couldn't leave France for such a long period of time to shoot the movie)."])</script><script>self.__next_f.push([1,"5:[\"$\",\"$L35\",null,{\"children\":[\"$undefined\",nu